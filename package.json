{
  "name": "pdfedit",
  "version": "0.1.0",
  "description": "Standalone client-side PDF text editor: render with pdf.js, edit in an overlay, export with pdf-lib.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:demo": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "npm run build:demo && start-server-and-test 'vite preview --port 5173 --strictPort' http://localhost:5173 'cypress run --browser chrome'",
    "test:e2e:open": "start-server-and-test 'vite --port 5173 --strictPort' http://localhost:5173 'cypress open'"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227"
  },
  "devDependencies": {
    "cypress": "^15.17.0",
    "start-server-and-test": "^3.0.11",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.0"
  }
}
